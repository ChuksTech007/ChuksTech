# Rename this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# When MONGODB_URI is set, MongoDB Atlas is used automatically.
# Leave commented out to use MySQL (local XAMPP).
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/iportfolio_db

# ── SMTP (Gmail) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_16char_app_password
SMTP_FROM=your.email@gmail.com
SMTP_FROM_NAME=Portfolio Contact
SMTP_TO=your.email@gmail.com
SMTP_SECURE=tls
